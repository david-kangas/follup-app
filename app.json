{
  "expo": {
    "name": "Follup",
    "slug": "follup-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F1EDE5"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.davidkangas.follup"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundColor": "#F1EDE5"
      },
      "package": "com.davidkangas.follup"
    },
    "extra": {
      "eas": {
        "projectId": "8bc6380c-7cb5-4338-9325-ca5b2892326a"
      }
    },
    "owner": "kangasd77",
    "plugins": [
      "expo-web-browser"
    ]
  }
}
